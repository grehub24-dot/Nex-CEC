{
  "version": 2,
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.8.0"
    },
    "api/admin/*.php": {
      "runtime": "vercel-php@0.8.0"
    },
    "api/student/*.php": {
      "runtime": "vercel-php@0.8.0"
    }
  },
  "routes": [
    { "src": "/css/(.*)", "dest": "/css/$1" },
    { "src": "/js/(.*)", "dest": "/js/$1" },
    { "src": "/images/(.*)", "dest": "/images/$1" },
    { "src": "/receipts/(.*)", "dest": "/receipts/$1" },
    { "src": "/uploads/(.*)", "dest": "/uploads/$1" },
    { "src": "/", "dest": "/api/index.php" },
    { "src": "/admin/(.*)", "dest": "/api/admin/$1" },
    { "src": "/student/(.*)", "dest": "/api/student/$1" },
    { "src": "/(.*)", "dest": "/api/$1" }
  ]
}
