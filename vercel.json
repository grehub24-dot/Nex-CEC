{
  "version": 2,
  "functions": {
    "Infotess-host/api/**/*.php": {
      "runtime": "vercel-php@0.8.0",
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "routes": [
    { "src": "/(css|js|images|receipts)/(.*)", "dest": "/Infotess-host/$1/$2" },
    { "src": "/(.*)\\.php", "dest": "/Infotess-host/api/index.php" },
    { "src": "/(.*)", "dest": "/Infotess-host/api/index.php" }
  ],
  "outputDirectory": "Infotess-host"
}
