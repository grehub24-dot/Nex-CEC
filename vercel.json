{
  "version": 2,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.8.0"
    }
  },
  "routes": [
    { "src": "/css/(.*)", "dest": "/Infotess-host/css/$1" },
    { "src": "/js/(.*)", "dest": "/Infotess-host/js/$1" },
    { "src": "/images/(.*)", "dest": "/Infotess-host/images/$1" },
    { "src": "/receipts/(.*)", "dest": "/Infotess-host/receipts/$1" },
    { "src": "/uploads/(.*)", "dest": "/Infotess-host/uploads/$1" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}
