{
  "version": 2,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.8.0"
    }
  },
  "routes": [
    { "src": "/css/(.*)", "dest": "/css/$1" },
    { "src": "/js/(.*)", "dest": "/js/$1" },
    { "src": "/images/(.*)", "dest": "/images/$1" },
    { "src": "/receipts/(.*)", "dest": "/receipts/$1" },
    { "src": "/uploads/(.*)", "dest": "/uploads/$1" },
    { "src": "/api/(.*)", "dest": "/api/index.php" },
    { "src": "/admin/(.*)", "dest": "/api/index.php" },
    { "src": "/student/(.*)", "dest": "/api/index.php" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}
