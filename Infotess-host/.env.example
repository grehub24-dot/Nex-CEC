# Supabase Configuration
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# SMTP / Email Configuration (Mailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USERNAME=your-gmail-address@gmail.com
SMTP_PASSWORD=your-16-char-gmail-app-password

# SMS Gateway Configuration (SMSHelper)
SMS_API_KEY=your-wigal-api-key
SMS_USERNAME=your-wigal-username
SMS_SENDER_ID=SCHOOL
SMS_ENDPOINT=https://frogapi.wigal.com.gh/api/v3/sms/send

# Application Settings
APP_NAME="INFOTESS SDMS"
APP_ENV=production
