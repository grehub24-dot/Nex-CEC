{
  "version": 2,
  "functions": {
    "**/*.php": {
      "runtime": "vercel-php@0.8.0",
      "maxDuration": 60
    }
  },
  "routes": [
    { "src": "/css/(.*)", "dest": "/css/$1" },
    { "src": "/js/(.*)", "dest": "/js/$1" },
    { "src": "/images/(.*)", "dest": "/images/$1" },
    { "src": "/receipts/(.*)", "dest": "/receipts/$1" },
    { "src": "/uploads/(.*)", "dest": "/uploads/$1" }
  ]
}
