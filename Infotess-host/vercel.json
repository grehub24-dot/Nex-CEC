{
  "version": 2,
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.8.0",
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "routes": [
    { "src": "/(css|js|images|receipts)/(.*)", "dest": "/$1/$2" },
    { "src": "/(.*)\\.php", "dest": "/api/index.php" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}
